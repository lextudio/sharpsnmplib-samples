    <Compile Remove="Unit/Pipeline/InformRequestMessageHandlerTestFixture.cs" />
    <Compile Remove="Unit/Pipeline/TrapV1MessageReceivedEventArgsTestFixture.cs" />
    <Compile Remove="Unit/Pipeline/TrapV2MessageReceivedEventArgsTestFixture.cs" />
    <Compile Remove="Unit/Pipeline/InformRequestMessageReceivedEventArgsTestFixture.cs" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Remove="Properties\Resources.resx" />
  </ItemGroup>
  <ItemGroup>
